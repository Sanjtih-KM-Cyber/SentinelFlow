# SentinelFlow Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit the actual .env file to version control.

# ─── API Keys for Passive Recon ───────────────────────────────────────────────
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
VIRUSTOTAL_API_KEY=
SECURITYTRAILS_API_KEY=
CHAOS_API_KEY=

# ─── Telegram Notifications ───────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Database ─────────────────────────────────────────────────────────────────
SF_DB_PATH=sentinelflow.db
