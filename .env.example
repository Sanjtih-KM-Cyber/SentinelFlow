# ============================================================
# SentinelFlow — Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env with real credentials to version control.
# ============================================================

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=PLACEHOLDER_BOT_TOKEN
TELEGRAM_CHAT_ID=PLACEHOLDER_CHAT_ID

# ── Optional: passive subdomain sources ──────────────────────
SHODAN_API_KEY=PLACEHOLDER_SHODAN_KEY
SECURITYTRAILS_API_KEY=PLACEHOLDER_ST_KEY

# ── Scan behaviour ────────────────────────────────────────────
SCAN_TIMEOUT_SEC=3600
MAX_CONCURRENT_TASKS=5
RESCAN_INTERVAL_HOURS=24

# ── Alert thresholds ──────────────────────────────────────────
ALERT_ON_SEVERITIES=critical,high

# ── Nuclei ────────────────────────────────────────────────────
NUCLEI_TEMPLATES_PATH=~/.local/nuclei-templates
NUCLEI_SEVERITY_FILTER=critical,high,medium

# ── FFuf wordlist ─────────────────────────────────────────────
FFUF_WORDLIST=/usr/share/wordlists/dirb/common.txt

# ── Cloud checks ─────────────────────────────────────────────
S3_CHECK_ENABLED=true
